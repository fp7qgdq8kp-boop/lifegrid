NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

LIFEGRID_PUBLIC_PORT=3010

POSTGRES_DB=lifegrid
POSTGRES_USER=lifegrid
POSTGRES_PASSWORD=change-this-postgres-password

DATABASE_URL=postgresql://lifegrid:change-this-postgres-password@db:5432/lifegrid?schema=public

WEB_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
WEB_PUSH_PRIVATE_KEY=replace-with-vapid-private-key
WEB_PUSH_SUBJECT=mailto:you@example.com

SEED_DATABASE=false
